local function verifyKey()
    local enteredKey = KeyBox.Text
    
    if enteredKey == "" then
        showNotification("✗ Please enter a key.", true)
        return
    end

    SubmitBtn.Visible = false
    SubmitBtn.Text = "⏳ Verifying..."

    task.spawn(function()
        local success, response = pcall(function()
            return game:HttpGet(API_URL .. "/verify/" .. enteredKey)
        end)

        SubmitBtn.Visible = true
        SubmitBtn.Text = "🐠 VERIFY"

        if success and response then
            local data = HttpService:JSONDecode(response)
            
            if data and data.valid then
                -- ✅ Clave válida
                local msg = "✅ " .. (data.message or "Clave válida")
                local typeMsg = "🔑 Tipo: " .. (data.type or "Desconocido")
                local expiresMsg = "📅 Expira: " .. (data.expires or "N/A")
                showNotification(msg .. " | " .. typeMsg .. " | " .. expiresMsg, false)
                
                keyVerified = true
                TweenService:Create(KeyWindow, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
                TweenService:Create(KeyWindow, TweenInfo.new(0.2), {Size = UDim2.new(0, 0, 0, 0)}):Play()
                task.wait(0.2)
                KeyWindow.Visible = false
                if StartOcean then
                    StartOcean()
                else
                    task.wait(0.1)
                    StartOcean()
                end
            else
                -- ❌ Clave inválida o expirada
                local errorMsg = data and data.message or "INVALID KEY! 🌊 Please check again."
                showNotification("✗ " .. errorMsg, true)
                KeyBox.Text = ""
            end
        else
            -- ⚠️ Error de conexión
            showNotification("⚠️ ERROR: Could not reach key server. Check your internet.", true)
            KeyBox.Text = ""
        end
    end)
end


    pcall(function()
        local mt = getrawmetatable(game)
        local old = mt.__namecall
        setreadonly(mt, false)

        mt.__namecall = newcclosure(function(self, ...)
            local args = {...}
            local method = getnamecallmethod()

            if (Ocean.SilentAim or Ocean.Wallbang) and method == "FireServer" then
                local name = tostring(self.Name):lower()
                if name:find("shoot") or name:find("gun") then
                    local murderer = GetMurderer()
                    if murderer then
                        local root = murderer:FindFirstChild("HumanoidRootPart")
                        if root then
                            args[1] = root.Position + Vector3.new(0, Ocean.ChestOffset, 0)
                        end
                    end
                end
            end
            return old(self, unpack(args))
        end)

        setreadonly(mt, true)
        SilentAimLoaded = true
    end)


        if input.KeyCode == Ocean.MapKey then
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if not myRoot then
                ShowNotification("⚠️ ERROR", "No tienes personaje", "error")
                return
            end
            local alivePlayers = {}
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer then
                    local char = p.Character
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    if root then
                        table.insert(alivePlayers, {player = p, root = root})
                    end
                end
            end
            if #alivePlayers == 0 then
                ShowNotification("❌ ERROR", "No hay jugadores vivos en el mapa", "error")
                return
            end
            local target = alivePlayers[math.random(1, #alivePlayers)]
            myRoot.CFrame = target.root.CFrame * CFrame.new(0, 2, Ocean.TeleportOffset)
            ShowNotification("🌀 TELEPORT", "Teletransportado a " .. target.player.Name .. " 🌊", "success")
        end

        -- Lobby (L)
        if input.KeyCode == Ocean.LobbyKey then
            local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if not root then
                ShowNotification("⚠️ ERROR", "No tienes personaje", "error")
                return
            end
            local targetPos = nil
            local keywords = {"lobby", "spawn", "waiting", "start", "hub", "lobbypart"}
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("BasePart") then
                    for _, kw in ipairs(keywords) do
                        if obj.Name:lower():find(kw) then
                            targetPos = obj.CFrame
                            break
                        end
                    end
                    if targetPos then break end
                end
            end
            if not targetPos then
                for _, model in ipairs(workspace:GetChildren()) do
                    if model:IsA("Model") then
                        for _, kw in ipairs(keywords) do
                            if model.Name:lower():find(kw) then
                                if model.PrimaryPart then
                                    targetPos = model.PrimaryPart.CFrame
                                else
                                    for _, part in ipairs(model:GetDescendants()) do
                                        if part:IsA("BasePart") then
                                            targetPos = part.CFrame
                                            break
                                        end
                                    end
                                end
                                break
                            end
                        end
                        if targetPos then break end
                    end
                end
            end
            if not targetPos then
                targetPos = CFrame.new(0, 100, 0)
                ShowNotification("⚠️ FALLBACK", "Usando coordenadas fijas del lobby", "alert")
            end
            if targetPos then
                root.CFrame = targetPos + Vector3.new(0, 5, 0)
                root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                ShowNotification("🏢 LOBBY", "Teletransportado al lobby 🌊", "success")
            else
                ShowNotification("❌ ERROR", "No se pudo encontrar el lobby", "error")
            end
        end

        -- Admin Panel (J)
        if input.KeyCode == Ocean.AdminKey then
            local adminPanel = CoreGui:FindFirstChild("Ocean_AdminPanel")
            if adminPanel then
                local newState = not adminPanel.Enabled
                adminPanel.Enabled = newState
                PlayAdminSound(newState and "Open" or "Close")
                ShowNotification("🛡️ OCEAN ADMIN", newState and "Panel Abierto 🌊" or "Panel Cerrado", newState and "success" or "error")
            end
        end

        -- TP Murderer (F5)
        if input.KeyCode == Ocean.TpMurdererKey then
            TeleportToMurderer()
        end

        -- TP Sheriff (F6)
        if input.KeyCode == Ocean.TpSheriffKey then
            TeleportToSheriff()
        end

        -- Otros toggles
        if input.KeyCode == Ocean.FakeLagKey then ToggleFakeLag() end
        if input.KeyCode == Ocean.ServerLagKey then ToggleServerLag() end
        if input.KeyCode == Ocean.SpeedGlitchKey then ToggleSpeedGlitch() end
        if input.KeyCode == Ocean.FlingSheriffKey then ToggleFlingSheriff() end
        if input.KeyCode == Ocean.FlingMurderKey then ToggleFlingMurder() end
    end)


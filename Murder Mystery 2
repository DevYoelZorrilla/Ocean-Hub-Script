    local function TeleportByName(playerName)
        local target = nil
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower() == playerName:lower() or p.DisplayName:lower() == playerName:lower() then
                target = p
                break
            end
        end

        if not target then
            ShowNotification("❌ ERROR", "Usuario no encontrado: " .. playerName, "error")
            return false
        end

        local targetRoot = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
        if not targetRoot then
            ShowNotification("⚠️ ERROR", "El jugador no tiene personaje activo", "error")
            return false
        end

        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not myRoot then
            ShowNotification("⚠️ ERROR", "No tienes personaje", "error")
            return false
        end

        myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 2, Ocean.TeleportOffset)
        ShowNotification("✅ TELETRANSPORTE EXITOSO", "Ahora estás con " .. target.Name .. " 🌊", "success")
        return true
    end

